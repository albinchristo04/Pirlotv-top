---
// src/pages/nhl.astro
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getMatchesBySport } from '../lib/data';
import { sportSeo, breadcrumbSchema } from '../lib/seo';
import { SITE_URL } from '../lib/config';

const matches = await getMatchesBySport('nhl');
const seo = {
  ...sportSeo('NHL', 'nhl', matches.length),
  title: `NHL En Vivo — Pirlo TV NHL · Hockey en Directo Gratis | PirloTV`,
};
const schema = breadcrumbSchema([{ name: 'NHL', url: SITE_URL + '/nhl/' }]);
---
<Base seo={seo} schema={schema}>
  <Breadcrumb items={[{ label: '🏒 NHL' }]} />
  <h1 class="hero__title" style="margin-bottom:0.5rem;">🏒 <span>Pirlo TV NHL</span> — Hockey en Vivo</h1>
  <p style="color:#7a7a9a;font-size:0.9rem;margin-bottom:2rem;">
    Hoy hay {matches.length} partidos de hockey NHL en vivo. Pirlo TV NHL · Roja Directa Hockey — gratis.
  </p>
  <MatchList matches={matches} groupByLeague={false} />
</Base>
