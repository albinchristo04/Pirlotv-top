---
// src/pages/nba.astro
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getMatchesBySport } from '../lib/data';
import { sportSeo, breadcrumbSchema } from '../lib/seo';
import { SITE_URL } from '../lib/config';

const matches = await getMatchesBySport('nba');
const seo = {
  ...sportSeo('NBA', 'nba', matches.length),
  title: `NBA En Vivo — Pirlo TV NBA · Baloncesto en Directo Gratis | PirloTV`,
};
const schema = breadcrumbSchema([{ name: 'NBA', url: SITE_URL + '/nba/' }]);
---
<Base seo={seo} schema={schema}>
  <Breadcrumb items={[{ label: '🏀 NBA' }]} />
  <h1 class="hero__title" style="margin-bottom:0.5rem;">🏀 <span>Pirlo TV NBA</span> — Baloncesto en Vivo</h1>
  <p style="color:#7a7a9a;font-size:0.9rem;margin-bottom:2rem;">
    Hoy hay {matches.length} partidos de baloncesto NBA en vivo. Pirlo TV NBA · Roja Directa NBA — gratis sin registro.
  </p>
  <MatchList matches={matches} groupByLeague={false} />
</Base>
