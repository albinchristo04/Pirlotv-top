---
// src/pages/futbol.astro
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getMatchesBySport } from '../lib/data';
import { sportSeo, breadcrumbSchema } from '../lib/seo';
import { SITE_URL } from '../lib/config';

const matches = await getMatchesBySport('futbol');
const seo = sportSeo('Fútbol', 'futbol', matches.length);
const schema = breadcrumbSchema([
  { name: 'Fútbol', url: SITE_URL + '/futbol/' },
]);
---
<Base seo={seo} schema={schema}>
  <Breadcrumb items={[{ label: 'Fútbol' }]} />
  <h1 class="hero__title" style="margin-bottom:0.5rem;">⚽ <span>Fútbol</span> en Vivo Hoy</h1>
  <p style="color:#7a7a9a;font-size:0.9rem;margin-bottom:2rem;">
    Hoy hay {matches.length} partidos de fútbol en vivo en Pirlo TV.
    LaLiga, Liga MX, Champions League, Copa Libertadores y más — todos en directo gratis.
    Pirlo TV Fútbol · Roja Directa Fútbol · Tarjeta Roja Fútbol.
  </p>
  <MatchList matches={matches} groupByLeague={true} />
</Base>
