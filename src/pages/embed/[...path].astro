---
import { getMatches2 } from '../../lib/data2';

export async function getStaticPaths() {
  const matches = await getMatches2();
  const paths = new Set<string>();

  matches.forEach(m => {
    m.channels.forEach(ch => {
      if (ch.url && ch.url.includes('/embed/')) {
        // Extract the path after /embed/
        const part = ch.url.split('/embed/')[1];
        if (part) paths.add(part);
      }
    });
  });

  return Array.from(paths).map(path => ({
    params: { path }
  }));
}

const { path } = Astro.params;
if (!path) return Astro.redirect('/404');

// Reconstruct the external URL
// Assuming the source is always pooembed.eu for this specific path
const targetUrl = `https://pooembed.eu/embed/${path}`;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Stream Player</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; }
        iframe { border: 0; width: 100%; height: 100%; }
    </style>
</head>
<body>
    <div id="click-catcher" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:9999; cursor:pointer; background:rgba(0,0,0,0.01);"></div>
    <iframe
        id="player-iframe"
        src={targetUrl}
        allowfullscreen
        allow="autoplay; fullscreen"
    ></iframe>
    <script>
        // Advanced Multi-Layer Popup Guard
        let clickCount = 0;
        const MAX_CLICKS = 5;

        (function() {
            const dummy = () => {};
            const protect = () => {
                try {
                    window.open = dummy;
                    window.alert = dummy;
                    window.confirm = dummy;
                    window.prompt = dummy;
                } catch (e) {}
            };
            protect();
            setInterval(protect, 500); // Re-enforce every 500ms
        })();

        const catcher = document.getElementById('click-catcher');
        catcher.onclick = function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            clickCount++;
            if (clickCount >= MAX_CLICKS) {
                this.style.display = 'none';
            }
        };
    </script>
</body>
</html>
