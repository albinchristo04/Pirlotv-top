---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import { getMatches } from '../lib/data';
import { homeSeo, websiteSchema, breadcrumbSchema } from '../lib/seo';
import { SITE_URL } from '../lib/config';

const matches = await getMatches();
const seo = homeSeo();
const buildTime = new Date().toLocaleString('es-ES', { timeZone: 'UTC', hour12: false });

const schema = [
  websiteSchema(),
  breadcrumbSchema([{ name: 'Pirlo TV', url: SITE_URL + '/' }]),
];
---
<Base seo={seo} schema={schema}>
  <section class="hero">
    <div class="hero__badges">
      <span class="badge badge--live">● En Vivo</span>
      <span class="badge">Pirlo TV</span>
      <span class="badge">Roja Directa</span>
      <span class="badge">Tarjeta Roja TV</span>
    </div>
    <h1 class="hero__title">
      <span>Pirlo TV</span> — Deportes en Vivo Gratis
    </h1>
    <p class="hero__sub">
      Ver {matches.length} partidos en vivo hoy gratis. Fútbol, MLB, NBA, NHL y más deportes
      en directo con múltiples canales en español, inglés y portugués.
    </p>
    <p class="hero__ts">🔄 Actualizado: {buildTime} UTC</p>
  </section>

  <!-- SEO text block (hidden visually but crawlable) -->
  <p style="font-size:0.82rem;color:#555;margin-bottom:1.5rem;">
    Pirlo TV es el mejor lugar para ver deportes en vivo gratis. Roja Directa · Tarjeta Roja TV · PirloTV
    — todos los partidos en un solo lugar. Béisbol MLB, baloncesto NBA, hockey NHL, fútbol LaLiga,
    Liga MX, Champions League, Copa Libertadores y más. Transmisión gratis sin registro.
  </p>

  <MatchList matches={matches} groupByLeague={true} />

  <!-- Sport hub links -->
  <h2 class="section-title">Deportes</h2>
  <div class="match-grid" style="margin-bottom:2rem;">
    {[
      { href: '/futbol/',   label: '⚽ Fútbol',     sub: 'LaLiga · Liga MX · Champions' },
      { href: '/mlb/',      label: '⚾ MLB',          sub: 'Pirlo TV MLB · Béisbol en vivo' },
      { href: '/nba/',      label: '🏀 NBA',          sub: 'Baloncesto en directo' },
      { href: '/nhl/',      label: '🏒 NHL',          sub: 'Hockey en vivo' },
      { href: '/motogp/',   label: '🏍 MotoGP',       sub: 'MotoGP en directo' },
      { href: '/beisbol/',  label: '⚾ Béisbol',      sub: 'Latino MLB en vivo' },
    ].map((hub) => (
      <a href={hub.href} class="match-card" style="text-decoration:none;">
        <div class="match-card__teams" style="font-size:1rem;">{hub.label}</div>
        <div class="match-card__league">{hub.sub}</div>
        <div class="match-card__live" style="margin-top:0.25rem;">Ver ahora →</div>
      </a>
    ))}
  </div>

  <!-- Brand pages -->
  <h2 class="section-title">Accesos Directos</h2>
  <div class="match-grid">
    {[
      { href: '/pirlo-tv/',              label: '⚡ Pirlo TV',                sub: 'pirlotv · pirlo tv en vivo' },
      { href: '/tarjeta-roja/',          label: '🟥 Tarjeta Roja TV',         sub: 'tarjeta roja en vivo gratis' },
      { href: '/roja-directa-pirlo-tv/', label: '🔴 Roja Directa Pirlo TV',   sub: 'roja directa pirlo tv' },
    ].map((b) => (
      <a href={b.href} class="match-card" style="text-decoration:none;">
        <div class="match-card__teams" style="font-size:0.95rem;">{b.label}</div>
        <div class="match-card__league">{b.sub}</div>
        <div class="match-card__live" style="margin-top:0.25rem;">Acceder →</div>
      </a>
    ))}
  </div>
</Base>
