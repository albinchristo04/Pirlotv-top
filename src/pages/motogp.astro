---
// src/pages/motogp.astro
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getMatchesBySport } from '../lib/data';
import { sportSeo, breadcrumbSchema } from '../lib/seo';
import { SITE_URL } from '../lib/config';

const matches = await getMatchesBySport('motogp');
const seo = {
  ...sportSeo('MotoGP', 'motogp', matches.length),
  title: `MotoGP En Vivo — Pirlo TV MotoGP · Motos en Directo Gratis | PirloTV`,
};
const schema = breadcrumbSchema([{ name: 'MotoGP', url: SITE_URL + '/motogp/' }]);
---
<Base seo={seo} schema={schema}>
  <Breadcrumb items={[{ label: '🏍 MotoGP' }]} />
  <h1 class="hero__title" style="margin-bottom:0.5rem;">🏍 <span>Pirlo TV MotoGP</span> — Motos en Vivo</h1>
  <p style="color:#7a7a9a;font-size:0.9rem;margin-bottom:2rem;">
    MotoGP en vivo hoy en Pirlo TV. {matches.length} eventos disponibles. Roja Directa MotoGP — gratis sin registro.
  </p>
  <MatchList matches={matches} groupByLeague={false} />
</Base>
