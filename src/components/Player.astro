---
// src/components/Player.astro
import type { Match } from '../lib/types';
import { PLAYER_BASE_URL, LANG_LABELS } from '../lib/config';

interface Props { match: Match; }
const { match: m } = Astro.props;

const langs = [...new Set(m.channels.map((c) => c.lang))];
const firstChannel = m.channels[0];
const initialSrc = firstChannel?.url || `${PLAYER_BASE_URL}/1/${firstChannel?.id ?? ''}`;
const servers = [1, 2, 3, 4];
---
<div class="player-wrapper" id="player-wrapper">
  <div id="click-catcher" class="click-catcher"></div>
  <iframe
    id="player-iframe"
    src={initialSrc}
    allowfullscreen
    allow="autoplay; fullscreen"
    loading="lazy"
    title={`${m.team1} vs ${m.team2} en vivo`}
  ></iframe>
</div>

<style>
  .player-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .click-catcher {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    cursor: pointer;
    background: rgba(0,0,0,0.01);
  }
  iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<div class="player-controls">
  {langs.length > 0 && (
    <div class="ctrl-group">
      <span class="ctrl-label">🌐 Idioma</span>
      <div class="ctrl-btns" id="lang-btns">
        {langs.map((lang, i) => (
          <button
            class={`ctrl-btn ${i === 0 ? 'active' : ''}`}
            data-lang={lang}
            aria-label={`Cambiar idioma a ${LANG_LABELS[lang] ?? lang}`}
          >
            {LANG_LABELS[lang] ?? lang.toUpperCase()}
          </button>
        ))}
      </div>
    </div>
  )}

  <div class="ctrl-group">
    <span class="ctrl-label">📡 Canal</span>
    <div class="ctrl-btns" id="ch-btns">
      {m.channels.map((ch, i) => (
        <button
          class={`ctrl-btn ${i === 0 ? 'active' : ''}`}
          data-ch={ch.id}
          data-lang={ch.lang}
          aria-label={`Canal ${i + 1}`}
        >
          {i + 1}
        </button>
      ))}
    </div>
  </div>

  <div class="ctrl-group" id="srv-group" style={firstChannel?.url ? "display:none" : ""}>
    <span class="ctrl-label">🖥 Servidor</span>
    <div class="ctrl-btns" id="srv-btns">
      {servers.map((s, i) => (
        <button
          class={`ctrl-btn ${i === 0 ? 'active' : ''}`}
          data-srv={s}
          aria-label={`Servidor ${s}`}
        >
          {s}
        </button>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ channels: m.channels, PLAYER_BASE_URL }}>
  let activeLang = channels[0]?.lang ?? '';
  let activeCh   = channels[0]?.id ?? '';
  let activeSrv  = 1;

  // Click-catcher logic to "swallow" 5 popup clicks
  let clickCount = 0;
  const MAX_CLICKS = 5;

  function initCatcher() {
    const catcher = document.getElementById('click-catcher');
    if (catcher) {
      catcher.onclick = () => {
        clickCount++;
        if (clickCount >= MAX_CLICKS) {
          catcher.style.display = 'none';
        }
      };
    }
  }
  initCatcher();

  function updatePlayer() {
    const iframe = document.getElementById('player-iframe');
    const srvGroup = document.getElementById('srv-group');
    const catcher = document.getElementById('click-catcher');
    if (!iframe) return;

    // Reset catcher and counter when changing streams
    clickCount = 0;
    if (catcher) catcher.style.display = 'block';

    // Find the current channel object to see if it has a direct URL
    const chObj = channels.find(c => c.id == activeCh && c.lang == activeLang) || channels.find(c => c.id == activeCh);
    
    if (chObj && chObj.url) {
      iframe.src = chObj.url;
      if (srvGroup) srvGroup.style.display = 'none';
    } else {
      iframe.src = `${PLAYER_BASE_URL}/${activeSrv}/${activeCh}`;
      if (srvGroup) srvGroup.style.display = 'block';
    }
  }

  function setActive(container, attr, val) {
    container.querySelectorAll('.ctrl-btn').forEach((b) => {
      b.classList.toggle('active', b.dataset[attr] == val);
    });
  }

  // Lang buttons
  document.getElementById('lang-btns')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.ctrl-btn[data-lang]');
    if (!btn) return;
    activeLang = btn.dataset.lang;
    // Pick first channel of that lang
    const ch = channels.find((c) => c.lang === activeLang);
    if (ch) {
      activeCh = ch.id;
      setActive(document.getElementById('ch-btns'), 'ch', activeCh);
    }
    setActive(document.getElementById('lang-btns'), 'lang', activeLang);
    updatePlayer();
  });

  // Channel buttons
  document.getElementById('ch-btns')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.ctrl-btn[data-ch]');
    if (!btn) return;
    activeCh = btn.dataset.ch;
    setActive(document.getElementById('ch-btns'), 'ch', activeCh);
    updatePlayer();
  });

  // Server buttons
  document.getElementById('srv-btns')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.ctrl-btn[data-srv]');
    if (!btn) return;
    activeSrv = btn.dataset.srv;
    setActive(document.getElementById('srv-btns'), 'srv', activeSrv);
    updatePlayer();
  });
</script>
