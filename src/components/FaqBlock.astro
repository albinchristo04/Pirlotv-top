---
// src/components/FaqBlock.astro
interface FaqItem { q: string; a: string; }
interface Props { items: FaqItem[]; }
const { items } = Astro.props;
---
<section class="faq" aria-labelledby="faq-heading">
  <div class="faq__title" id="faq-heading">Preguntas Frecuentes</div>
  <dl>
    {items.map((item) => (
      <>
        <dt>{item.q}</dt>
        <dd>{item.a}</dd>
      </>
    ))}
  </dl>
</section>
